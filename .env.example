# ============================================================
#  PadelClub — Environment Variables
#  1. Copy this file to .env.local
#  2. Fill in your values from the Supabase dashboard
#  3. Never commit .env.local to git
# ============================================================

# Supabase — Settings → API in your project dashboard
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here

# Supabase service role key — only used server-side, never exposed to browser
# Settings → API → service_role key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# App URL — used for auth redirects
# Local: http://localhost:3000
# Production: https://your-app.vercel.app
NEXT_PUBLIC_APP_URL=http://localhost:3000
